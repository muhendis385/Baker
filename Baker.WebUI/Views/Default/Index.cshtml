
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("DefaultHead")

<body>
    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>
    <!-- Spinner End -->
    <!-- Topbar Start -->
    <!-- Topbar End -->
    <!-- Navbar Start -->
    @await Component.InvokeAsync("DefaultNavbar")
    <!-- Navbar End -->
    <!-- Carousel Start -->
    @await Component.InvokeAsync("DefaultCareusel")
    <!-- Carousel End -->
    <!-- Facts Start -->
    @await Component.InvokeAsync("DefaultStatistic")
    <!-- Facts End -->
    <!-- About Start -->
    @await Component.InvokeAsync("DefaultAbout")

    <!-- About End -->
    <!-- Product Start -->
    @await Component.InvokeAsync("DefaultContact")
    @await Component.InvokeAsync("DefaultProduct")

    <!-- Product End -->
    <!-- Service Start -->
    @await Component.InvokeAsync("DefaultService")
    <!-- Service End -->
    <!-- Team Start -->
    @await Component.InvokeAsync("DefaultChef")
    <!-- Team End -->
    <!-- Testimonial Start -->
    @await Component.InvokeAsync("DefaultTestimonial")
    @await Component.InvokeAsync("DefaultSubscribe")
    <!-- Testimonial End -->
    <!-- Footer Start -->
    @await Component.InvokeAsync("DefaultFooter")
    <!-- Footer End -->
  
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square rounded-circle back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/baker-1.0.0/baker-1.0.0/lib/wow/wow.min.js"></script>
    <script src="~/baker-1.0.0/baker-1.0.0/lib/easing/easing.min.js"></script>
    <script src="~/baker-1.0.0/baker-1.0.0/lib/waypoints/waypoints.min.js"></script>
    <script src="~/baker-1.0.0/baker-1.0.0/lib/counterup/counterup.min.js"></script>
    <script src="~/baker-1.0.0/baker-1.0.0/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/baker-1.0.0/baker-1.0.0/js/main.js"></script>
</body>

</html>