@model Baker.WebUI.Dtos.About.CreateAboutDto
@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />



<div class="container">
    <div class="form-card">
        <h2 class="form-header">Yeni Hakkımda Kaydı</h2>

        <form method="post">
         

            <div class="form-group">
                <label>Başlık</label>
                <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Title" />
            </div>
            <br />
            <div class="form-group">
                <label>Description</label>
                <input type="text" asp-for="Description" class="form-control" placeholder="Örn: Description" />
            </div>
            <br />

          

            

            <button type="submit" class="btn btn-bakery">Kişiyi Fırına Ekle (Kaydet)</button>
        </form>
    </div>
</div>

<style>
    :root {
        --bakery-dark: #2d2424;
        --bakery-primary: #e67e22;
        --bakery-light: #fdf2e9; 
        --bakery-border: rgba(224, 212, 195, 0.4);
        --bakery-input-bg: #fcfaf8;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        background-color: #f8f4f0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
    }

    .container {
        width: 100%;
        max-width: 500px;
        padding: 20px;
    }

    .form-card {
        background: #ffffff;
        padding: 60px 40px 40px 40px; 
        border-radius: 28px;
        border: 1px solid var(--bakery-border);
        box-shadow: 0 25px 50px -12px rgba(78, 52, 46, 0.12);
        position: relative;
        overflow: hidden; 
    }


    .status-badge {
        position: absolute;
        top: 25px;
        right: 25px;
        background: var(--bakery-light);
        color: var(--bakery-primary);
        padding: 6px 14px;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border: 1px solid rgba(230, 126, 34, 0.2);
    }

    .form-header {
        color: var(--bakery-dark);
        font-size: 1.8rem;
        font-weight: 800;
        text-align: left; 
        margin-bottom: 35px;
        margin-top: 10px;
    }

        .form-header::after {
            content: '';
            display: block;
            width: 50px;
            height: 4px;
            background: var(--bakery-primary);
            margin: 12px 0 0 0; 
            border-radius: 10px;
        }

 
    .bakery-form-group {
        margin-bottom: 24px;
    }

    label {
        display: block;
        color: var(--bakery-dark);
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 8px;
        padding-left: 4px;
    }


    .form-card .form-control {
        width: 100%;
        border-radius: 16px;
        border: 2px solid transparent;
        background-color: var(--bakery-input-bg);
        padding: 15px 20px;
        font-size: 1rem;
        color: var(--bakery-dark);
        transition: var(--transition);
        box-sizing: border-box;
        height: auto; 
    }

        .form-card .form-control:focus {
            outline: none;
            background-color: #ffffff;
            border-color: var(--bakery-primary);
            box-shadow: 0 8px 20px rgba(230, 126, 34, 0.08);
            color: var(--bakery-dark);
        }

        .form-card .form-control::placeholder {
            color: #bcaaa4;
            opacity: 0.7;
        }

    .btn-bakery {
        background: var(--bakery-dark);
        color: #ffffff;
        border: none;
        padding: 18px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1.05rem;
        width: 100%;
        margin-top: 15px;
        cursor: pointer;
        transition: var(--transition);
        display: block; 
        text-align: center;
    }

        .btn-bakery:hover {
            background: var(--bakery-primary);
            color: #ffffff;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(230, 126, 34, 0.25);
            text-decoration: none;
        }

    .btn-cancel {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #999;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: var(--transition);
    }

        .btn-cancel:hover {
            color: var(--bakery-dark);
            text-decoration: none;
        }


    .form-card::before {
        display: none;
    }
</style>