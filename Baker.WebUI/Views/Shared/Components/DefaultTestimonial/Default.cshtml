@model List<Baker.WebUI.Dtos.Testimonial.ResultTestimonialDto>

<div class="container-xxl bg-light my-6 py-6 pb-0">
    <div class="container">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">// Müşteri Yorumları</p>
            <h1 class="display-6 mb-4">Sizlerden Gelen Yorumlar</h1>
        </div>
        <div class="owl-carousel testimonial-carousel wow fadeInUp" data-wow-delay="0.1s">

            @foreach (var item in Model)
            {
                <div class="testimonial-item bg-white rounded p-4">
                    <div class="d-flex align-items-center mb-4">
                        <img class="flex-shrink-0 rounded-circle border p-1" src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px;">
                        <div class="ms-4">
                            <h5 class="mb-1">@item.Name</h5>
                            <span>@item.JobName</span>
                        </div>
                    </div>
                    <p class="mb-0">@item.Description</p>
                </div>
            }

        </div>

        @* Newsletter Kısmı *@
        
    </div>
</div>