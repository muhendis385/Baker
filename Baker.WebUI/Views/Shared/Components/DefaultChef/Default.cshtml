@model List<Baker.WebUI.Dtos.Chef.ResultChefDto>

<div class="container-xxl py-6">
    <div class="container">
        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">// Ekibimiz</p>
            <h1 class="display-6 mb-4">Ustalıkla Hazırlayan Profesyonel Şeflerimiz</h1>
        </div>
        <div class="row g-4">
            @{
                double delay = 0.1; // Animasyon gecikmesi başlangıcı
            }

            @* Model'den sadece ilk 4 şefi alıyoruz *@
            @foreach (var item in Model.Take(4))
            {
                <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="@(delay.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))s">
                    <div class="team-item text-center rounded overflow-hidden">
                        <img class="img-fluid" src="@item.Imageurl" alt="@item.Name" style="width: 100%; height: 300px; object-fit: cover;">
                        <div class="team-text">
                            <div class="team-title">
                                <h5>@item.Name</h5>
                                <span>@item.Title</span>
                            </div>
                            <div class="team-social">
                                <a class="btn btn-square btn-light rounded-circle" href=""><i class="fab fa-facebook-f"></i></a>
                                <a class="btn btn-square btn-light rounded-circle" href=""><i class="fab fa-twitter"></i></a>
                                <a class="btn btn-square btn-light rounded-circle" href=""><i class="fab fa-instagram"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                delay += 0.2; // Her şef için animasyonu 0.2 saniye kaydırıyoruz
            }
        </div>
    </div>
</div>