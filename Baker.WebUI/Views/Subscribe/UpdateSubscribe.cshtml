@model Baker.WebUI.Dtos.Subscribe.UpdateSubscribeDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Abone Güncelle - Baker</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --bakery-dark: #2d2424;
            --bakery-primary: #e67e22;
            --bakery-accent: #f39c12;
            --bakery-bg: #faf7f2;
            --bakery-card: #ffffff;
            --bakery-light: #fdf2e9;
            --bakery-border: rgba(0, 0, 0, 0.05);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background-color: var(--bakery-bg);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            width: 100%;
            max-width: 480px;
            padding: 20px;
        }

        .form-card {
            background: var(--bakery-card);
            padding: 55px 40px 40px 40px;
            border-radius: 32px;
            border: 1px solid var(--bakery-border);
            box-shadow: 0 20px 40px rgba(78, 52, 46, 0.08);
            position: relative;
            overflow: hidden;
        }

            /* Üst renk şeridi */
            .form-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 6px;
                background: linear-gradient(90deg, var(--bakery-primary), var(--bakery-accent));
            }

        /* Emoji yerine Modern ID Badge */
        .status-badge {
            position: absolute;
            top: 25px;
            right: 25px;
            background: var(--bakery-light);
            color: var(--bakery-primary);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .form-header {
            color: var(--bakery-dark);
            font-size: 1.75rem;
            font-weight: 800;
            text-align: left;
            margin-bottom: 8px;
        }

            .form-header::after {
                content: '';
                display: block;
                width: 40px;
                height: 4px;
                background: var(--bakery-primary);
                margin: 12px 0 25px 0;
                border-radius: 10px;
            }

        .form-subtitle {
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 30px;
            display: block;
        }

        .bakery-form-group {
            margin-bottom: 24px;
        }

        label {
            color: var(--bakery-dark);
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: block;
            padding-left: 4px;
        }

        /* Inputların modernist hali */
        .form-card .form-control {
            width: 100%;
            border-radius: 16px;
            border: 2px solid #f1f1f1;
            background-color: #fcfcfc;
            padding: 15px 20px;
            font-size: 1rem;
            color: var(--bakery-dark);
            transition: var(--transition);
            box-sizing: border-box;
            height: auto;
        }

            .form-card .form-control:focus {
                outline: none;
                border-color: var(--bakery-primary);
                background-color: #fff;
                box-shadow: 0 8px 20px rgba(230, 126, 34, 0.08);
            }

        /* Ana Buton */
        .btn-bakery {
            background: var(--bakery-dark);
            color: white;
            border: none;
            padding: 18px;
            border-radius: 16px;
            font-weight: 700;
            font-size: 1rem;
            width: 100%;
            margin-top: 15px;
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
        }

            .btn-bakery:hover {
                background: var(--bakery-primary);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(230, 126, 34, 0.3);
                text-decoration: none;
            }

        /* Geri Dön Linki */
        .btn-cancel {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #999;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: var(--transition);
        }

            .btn-cancel:hover {
                color: var(--bakery-dark);
                text-decoration: none;
                transform: translateX(-3px);
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="form-card">
            <span class="status-badge">ID: #@Model.SubscribeId</span>

            <h2 class="form-header">Abone Güncelle</h2>
            <span class="form-subtitle">Abone maili düzenleyin.</span>

            <form method="post">
                @* ID'yi gizli alan olarak taşımanız gerekir *@
                <input type="hidden" asp-for="SubscribeId" />

                <div class="bakery-form-group">
                    <label asp-for="Mail">Kişinin Güncellenecek Maili</label>
                    <input type="email" asp-for="Mail" class="form-control" placeholder="Örn: example@mail.com" required />
                    <span asp-validation-for="Mail" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-bakery">Maili Güncelle (Kaydet)</button>

                <a href="/Subscribe/SubscribeList" class="btn-cancel">← Değişiklik Yapmadan Geri Dön</a>
            </form>
        </div>
    </div>

</body>
</html>